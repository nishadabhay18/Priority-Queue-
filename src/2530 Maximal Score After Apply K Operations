class Solution {
    // TC-> O(nlogn +klogn) SC-> O(n)
    public long maxKelements(int[] nums, int k) {
        int n = nums.length;
        PriorityQueue<Integer> pq = new PriorityQueue<>(Collections.reverseOrder());
        for(int i=0; i<n; i++) pq.add(nums[i]);
        long score = 0;
        while(k != 0){
            int val = pq.remove();
            score += val;
            pq.add((int) Math.ceil(val / 3.0));
            k--;
        }
        return score;
    }
}
